{
  "editor.fontFamily": "JetBrains Mono",
  "editor.letterSpacing": 0,
  "workbench.tree.indent": 40,

  // Custom Language settings
  "[javascript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.formatOnType": true,
  },
  "editor.cursorBlinking": "phase",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.fontSize": 16,
  "workbench.editor.splitInGroupLayout": "vertical",
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
  },
  "clang-format.executable": "/usr/bin/clang-format",
  "clang-format.style": "google",
  "clang-format.language.c.enable": true,
  "[c]": {
    "editor.insertSpaces": false,
    "editor.defaultFormatter": "xaver.clang-format",
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true,
  },
  "files.insertFinalNewline": true,
  "editor.inlineSuggest.enabled": true,
  "debug.internalConsoleOptions": "neverOpen",
  "code-runner.runInTerminal": true,
  "git.enableSmartCommit": true,
  "terminal.integrated.fontFamily": "monospace",
  "liveServer.settings.donotShowInfoMsg": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
    "javascript": true,
    "python": true,
    "typescriptreact": true,
    "c": false,
  },
  "[typescriptreact]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "emmet.excludeLanguages": [],
  "emmet.includeLanguages": {
    "javascript": "javascriptreact",
  },
  "security.workspace.trust.untrustedFiles": "open",
  "editor.bracketPairColorization.enabled": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "emmet.showSuggestionsAsSnippets": true,
  "files.associations": {
    "*html": "html",
    "*njk": "html",
    "*.css": "tailwindcss",
  },
  "workbench.productIconTheme": "adwaita",
  "files.autoSave": "afterDelay",
  "workbench.iconTheme": "bearded-icons",
  "workbench.colorTheme": "Bearded Theme OLED (Experimental)",
  "leetcode.workspaceFolder": "/home/afrokk/potatoDSA",
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": true,
  },
  "terminal.integrated.inheritEnv": true,
  "indentRainbow.colors": [
    "rgba(24, 78, 119,0.15)",
    "rgba(30, 96, 145,0.15)",
    "rgba(26, 117, 159, 0.15)",
    "rgba(22, 138, 173,0.15)",
    "rgba(52, 160, 164,0.15)",
    "rgba(82, 182, 154,0.15)",
    "rgba(82, 182, 154,0.1)",
    "rgba(82, 182, 154,0.05)",
    "rgba(82, 182, 154,0.025)",
  ],
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "remote.autoForwardPortsSource": "hybrid",
  "redhat.telemetry.enabled": false,
  "workbench.sideBar.location": "right",
  "github.copilot.editor.enableAutoCompletions": true,
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "workbench.startupEditor": "none",
  "docker.extension.enableComposeLanguageServer": false,
  "markdown-preview-enhanced.previewTheme": "atom-dark.css",
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.tools.terminal.outputLocation": "chat",
  "chat.viewSessions.orientation": "stacked",
  "chat.viewSessions.enabled": false,
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "diffEditor.ignoreTrimWhitespace": false,
}
